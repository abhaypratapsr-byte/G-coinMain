{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd gcoin-backend && npm install"
  },
  "deploy": {
    "startCommand": "cd gcoin-backend && node server.js",
    "restartPolicyType": "on-failure",
    "restartPolicyMaxRetries": 10
  }
}
